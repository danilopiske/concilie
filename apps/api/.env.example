# Backend Environment Variables — Concilie API
# Copie para .env e preencha os valores reais (não commitar o .env!)

# ── Banco de Dados ──────────────────────────────
# Tipo: "mysql" ou "sqlite"
DATABASE_TYPE=sqlite

# MySQL (se DATABASE_TYPE=mysql)
MYSQL_SERVER=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=sua_senha_aqui
MYSQL_DB=concilie

# SQLite (se DATABASE_TYPE=sqlite)
SQLITE_DB_PATH=../../data/concilie.db

# ── Debug ────────────────────────────────────────
# DEBUG_SQL=true para ver queries SQL no console
DEBUG_SQL=false
# DEBUG=true ativa detalhes de erro no JSON de resposta (desabilitar em produção)
DEBUG=false
# ENV: development | staging | production
ENV=development

# ── Autenticação JWT ─────────────────────────────
# Gere com: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-change-in-production-minimum-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ── CORS ─────────────────────────────────────────
# ALLOWED_ORIGINS_STR sobrescreve toda a lista de origens permitidas.
# Use em staging/produção para restringir origens explicitamente.
# Formato: JSON array como string. Ex: '["https://app.concilie.com.br"]'
# Se não definido, usa os defaults de localhost definidos em config.py.
# ALLOWED_ORIGINS_STR=["https://app.concilie.com.br"]

# URL do frontend (adicionada ao CORS se ALLOWED_ORIGINS_STR não estiver definido)
# FRONTEND_URL=https://app.concilie.com.br

# Domínio público do Railway (adicionado ao CORS automaticamente se definido)
# RAILWAY_PUBLIC_DOMAIN=seu-app.railway.app

# ── AI / OpenAI ──────────────────────────────────
# Chave de API da OpenAI (deixar vazio para desabilitar funcionalidades de IA)
OPENAI_API_KEY=
OPENAI_API_BASE=https://api.openai.com/v1
AI_MODEL=gpt-4o
