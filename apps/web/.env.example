# Frontend Environment Variables — Concilie Web
# Copie para .env.local e preencha os valores reais (não commitar o .env.local!)

# ── API ───────────────────────────────────────────
# URL do backend FastAPI (sem barra no final)
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── Playwright E2E (opcional, apenas para testes) ─
# Credenciais usadas nos smoke tests E2E
# E2E_USER=admin
# E2E_PASSWORD=sua_senha_de_teste
# PLAYWRIGHT_BASE_URL=http://localhost:3000
